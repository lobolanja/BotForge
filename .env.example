# Token for the Telegram bot
# Required: replace with the token from BotFather.
TELEGRAM_TOKEN=<telegram_bot_token>

# Runtime environment. Keep development locally; use production for beta.
# Production mode rejects documented development secrets at startup.
BOTFORGE_ENV=development

# BotForge database configuration.
# In Docker Compose, DB_HOST must be the PostgreSQL service name.
DB_HOST=postgres
# Development defaults. Change them before production.
DB_USER=botforge
DB_PASSWORD=botforge_dev_password
DB_NAME=botforge
DB_PORT=5432

# Ollama container configuration.
OLLAMA_HOST=http://ollama:11434
# Used by the ollama-pull helper container. Keep it aligned with the active
# profile's llm_model. If these values differ, Compose may pull one model while
# the bot tries to use another at runtime.
OLLAMA_MODEL=gemma3:4b
# Maximum seconds to wait for a single AI response before sending fallback text.
AI_TIMEOUT_SECONDS=60
# Safety cap for long model replies sent back to Telegram.
AI_MAX_RESPONSE_CHARS=4000

# Active bot profile configuration.
# Add new profiles under bot_profiles/<profile_id>/profile.json.
BOT_PROFILE=default_dev
BOT_PROFILES_DIR=bot_profiles

# Required usage policy versions. Changing either value requires users to
# accept the policy again before protected bot functionality is available.
BOT_POLICY_VERSION=2026-05-08
BOT_PRIVACY_NOTICE_VERSION=2026-05-08
BOT_POLICY_URL=

# Invite limits.
INVITE_TOKEN_TTL_HOURS=24
CAMPAIGN_INVITE_MAX_USES_LIMIT=1000

# Inbound message recovery policy.
MESSAGE_PROCESSING_STALE_MINUTES=30
MESSAGE_EXPIRATION_HOURS=24
MESSAGE_MAX_RETRIES=1

# Optional analytics/training consent is separate from required policy
# acceptance and defaults to disabled.
BOT_ANALYTICS_CONSENT_ENABLED=false
BOT_TRAINING_CONSENT_ENABLED=false

