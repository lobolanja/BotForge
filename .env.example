# Token for the Telegram bot
# Required: replace with the token from BotFather.
TELEGRAM_TOKEN=<telegram_bot_token>

# Runtime environment. Keep development locally; use production for beta.
# Production mode rejects documented development secrets at startup.
BOTFORGE_ENV=development

# BotForge database configuration.
# In Docker Compose, DB_HOST must be the PostgreSQL service name.
DB_HOST=postgres
# Development defaults. Change them before production.
DB_USER=botforge
DB_PASSWORD=botforge_dev_password
DB_NAME=botforge
DB_PORT=5432

# Ollama container configuration.
OLLAMA_HOST=http://ollama:11434
# Used by the ollama-pull helper container. Keep it aligned with the active
# profile's llm_model. If these values differ, Compose may pull one model while
# the bot tries to use another at runtime.
OLLAMA_MODEL=gemma3:4b
# Maximum seconds to wait for a single AI response before sending fallback text.
AI_TIMEOUT_SECONDS=60
# Safety cap for long model replies sent back to Telegram.
AI_MAX_RESPONSE_CHARS=4000

# LLM provider routing. Use "profile" so each bot profile selects its own
# primary provider. Set "ollama" or "nvidia" here only to force a global
# override for every profile.
LLM_PRIMARY_PROVIDER=profile
LLM_FALLBACK_PROVIDER=nvidia
LLM_FALLBACK_QUEUE_WAIT_SECONDS=100

# NVIDIA NIM hosted API fallback. Get an API key from build.nvidia.com and pick
# a model from the NVIDIA API Catalog. Leave NVIDIA_API_KEY empty for local-only
# development; the bot only requires it if fallback is actually used.
NVIDIA_API_KEY=<nvidia_api_key>
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# Abuse prevention and AI capacity limits. These are in-memory and reset when
# the bot process restarts.
MAX_MESSAGE_CHARS=4000
USER_MESSAGES_PER_MINUTE=6
USER_AI_REQUESTS_PER_HOUR=60
CHAT_MESSAGES_PER_MINUTE=30
GLOBAL_ACTIVE_AI_REQUESTS=2
GLOBAL_AI_QUEUE_SIZE=20
ADMIN_INVITES_PER_HOUR=50

# Conversation memory. BotForge keeps a bounded recent window in PostgreSQL and
# caches it in process after the first load for each user/profile. When 6
# unsummarized messages are present, the oldest 5 are compacted into a summary.
MEMORY_ENABLED=true
MEMORY_RECENT_MESSAGES=10
MEMORY_COMPACTION_TRIGGER_MESSAGES=6
MEMORY_COMPACTION_SOURCE_MESSAGES=5
MEMORY_MAX_MESSAGE_CHARS=4000
MEMORY_COMPACTED_MAX_CHARS=2000

# Active bot profile configuration.
# Add new profiles under bot_profiles/<profile_id>/profile.json.
BOT_PROFILE=default_dev
BOT_PROFILES_DIR=bot_profiles

# Optional first-admin bootstrap. When both email and bot username are set,
# Docker startup creates one admin invite after migrations if no admin exists.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_BOT_USERNAME=
BOOTSTRAP_ADMIN_INVITE_TTL_HOURS=24
BOOTSTRAP_ADMIN_INVITE_FORCE=false

# Required usage policy versions. Changing either value requires users to
# accept the policy again before protected bot functionality is available.
BOT_POLICY_VERSION=2026-05-08
BOT_PRIVACY_NOTICE_VERSION=2026-05-08
BOT_POLICY_URL=

# Invite limits.
INVITE_TOKEN_TTL_HOURS=24
CAMPAIGN_INVITE_MAX_USES_LIMIT=1000

# Inbound message recovery policy.
MESSAGE_PROCESSING_STALE_MINUTES=30
MESSAGE_EXPIRATION_HOURS=24
MESSAGE_MAX_RETRIES=1

# Optional analytics/training consent is separate from required policy
# acceptance and defaults to disabled.
BOT_ANALYTICS_CONSENT_ENABLED=false
BOT_TRAINING_CONSENT_ENABLED=false
